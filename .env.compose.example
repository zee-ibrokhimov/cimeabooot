# Copy to .env (next to docker-compose.yml) and fill in. Do NOT commit .env.

# --- database (used by both the db container and the app) ---
POSTGRES_USER=cimea
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=cimea

# --- app secrets ---
# Long random string that unlocks /dashboard and user management.
ADMIN_TOKEN=change-me-to-a-long-random-secret
# Random string used to hash visitor IPs (leave blank to not store IPs at all).
IP_SALT=another-long-random-value

# Host port to expose the app on (put HTTPS in front of it).
APP_PORT=3000
