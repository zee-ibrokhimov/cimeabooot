# -----------------------------------------------------------------------------
# CIMEA Helper Pro — dashboard environment
# Copy to .env.local for local dev; set these in Coolify → your app → Environment.
# -----------------------------------------------------------------------------

# Your PostgreSQL connection string. On Coolify, create a PostgreSQL resource and
# use its connection URL. If the app and DB are in the same Coolify project you
# can use the internal hostname (no TLS needed).
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://postgres:password@postgres:5432/cimea

# TLS to Postgres. Leave unset on a trusted private LAN. If your DB is remote:
#   DATABASE_SSL=true            -> TLS WITH certificate verification (secure).
#   DATABASE_CA_CERT=<PEM>       -> provide your CA cert for a self-signed/internal CA.
#   DATABASE_SSL_INSECURE=true   -> TLS without verifying the cert (LAST RESORT only).
# DATABASE_SSL=true

# Max pooled connections (optional).
# DATABASE_POOL_MAX=5

# --- Client IP behind your proxy ---
# Login rate-limiting and geo use the client IP. A Cloudflare Tunnel sets a
# trustworthy cf-connecting-ip automatically (recommended). Without Cloudflare,
# configure Traefik/your proxy to STRIP client-supplied X-Forwarded-For/X-Real-Ip,
# or IP-based limits can be spoofed. The email-based login lockout does not
# depend on the IP and remains effective either way.

# Password that protects /dashboard and the admin/GET endpoints.
# Use a long random string. WITHOUT this, the dashboard stays locked.
ADMIN_TOKEN=change-me-to-a-long-random-secret

# Salt used to hash visitor IPs so the raw IP is never stored. Fail-closed:
# if this is unset, IPs are NOT hashed or stored at all (ip_hash = null).
# Use a long random value, different from ADMIN_TOKEN.
IP_SALT=another-long-random-value

# --- Telegram access-code login ---
# Create a bot with @BotFather -> put its token here.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# YOUR Telegram numeric id (message @userinfobot to get it). Approval prompts go here.
TELEGRAM_ADMIN_CHAT_ID=123456789
# A random string; set the SAME value when registering the webhook (below).
TELEGRAM_WEBHOOK_SECRET=another-random-string
# After deploy, register the webhook once (replace TOKEN/domain/SECRET):
#   curl "https://api.telegram.org/botTOKEN/setWebhook?url=https://YOUR-DOMAIN/api/telegram/webhook&secret_token=SECRET"

# Notes:
# - The users / sessions / usage_logs tables are created automatically on first use.
# - /api/track requires a valid user session token (users log in via the
#   extension), so there is no separate ingest key.
# - Country/city geo is only populated if your reverse proxy provides it
#   (Cloudflare sets cf-ipcountry). Without GeoIP they are simply left null.
