# -----------------------------------------------------------------------------
# CIMEA Helper Pro — dashboard environment
# Copy to .env.local for local dev; set these in Coolify → your app → Environment.
# -----------------------------------------------------------------------------

# Your PostgreSQL connection string. On Coolify, create a PostgreSQL resource and
# use its connection URL. If the app and DB are in the same Coolify project you
# can use the internal hostname (no TLS needed).
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://postgres:password@postgres:5432/cimea

# Set to true only if your Postgres requires TLS (usually not on a private LAN).
# DATABASE_SSL=false

# Max pooled connections (optional).
# DATABASE_POOL_MAX=5

# Password that protects /dashboard and the admin/GET endpoints.
# Use a long random string. WITHOUT this, the dashboard stays locked.
ADMIN_TOKEN=change-me-to-a-long-random-secret

# Salt used to hash visitor IPs so the raw IP is never stored. Fail-closed:
# if this is unset, IPs are NOT hashed or stored at all (ip_hash = null).
# Use a long random value, different from ADMIN_TOKEN.
IP_SALT=another-long-random-value

# Notes:
# - The users / sessions / usage_logs tables are created automatically on first use.
# - /api/track requires a valid user session token (users log in via the
#   extension), so there is no separate ingest key.
# - Country/city geo is only populated if your reverse proxy provides it
#   (Cloudflare sets cf-ipcountry). Without GeoIP they are simply left null.
